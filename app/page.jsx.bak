                </div>
              </div>

              {/* Portrait image — tall */}
              <div className="w-full rounded-[1.8rem] overflow-hidden group" style={{ aspectRatio: '4/5', border: '1px solid rgba(255,255,255,0.1)', boxShadow: '0 20px 60px rgba(0,11,33,0.6)' }}>
                <img src="/img/gallery/9.jpeg" alt="Souhardya Bose" className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              </div>

              {/* Two square images side by side */}
              <div className="grid grid-cols-2 gap-4">
                <div className="aspect-square rounded-[1.5rem] overflow-hidden group" style={{ border: '1px solid rgba(255,255,255,0.08)' }}>
                  <img src="/img/gallery/10.jpeg" alt="Teaching" className="w-full h-full object-cover group-hover:scale-108 transition-transform duration-700" />
                </div>
                <div className="aspect-square rounded-[1.5rem] overflow-hidden group" style={{ border: '1px solid rgba(255,255,255,0.08)' }}>
                  <img src="/img/gallery/16.jpeg" alt="Speaking" className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                </div>
              </div>

              {/* Wide fourth image — fills remaining space */}
              <div className="w-full rounded-[1.5rem] overflow-hidden group" style={{ aspectRatio: '16/7', border: '1px solid rgba(255,255,255,0.08)' }}>
                <img src="/img/gallery/11.jpeg" alt="Keynote" className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              </div>

              {/* Quick fact tag at bottom */}
              <div className="bg-gradient-to-r from-[#4361EE] to-[#7C3AED] text-white rounded-2xl px-5 py-4 flex items-center gap-3 shadow-lg">
                <Mic size={18} className="shrink-0" />
                <div>
                  <div className="font-black text-sm">50+ Keynote Talks</div>
                  <div className="text-white/60 text-xs">National & International stages</div>
                </div>
              </div>
            </div>

            {/* CENTRE: Bio + highlights */}
            <div className="animate-fadeUp" style={{ animationFillMode: 'both', animationDelay: '0.1s' }}>
              <h2 className="text-4xl md:text-5xl tracking-tight text-white mb-4 leading-[1.1]" style={{ fontWeight: 300 }}>
                Professor. <span style={{ fontWeight: 700 }}>Builder.</span><br />
                <span className="blue-grad-text" style={{ fontWeight: 700 }}>Community Leader.</span>
              </h2>
              <p className="text-white/60 text-[15px] leading-relaxed mb-8">
                I&apos;m <span className="font-semibold text-white">Souhardya Bose</span> — Assistant Professor &amp; Head of Student Success at Lovely Professional University. I bridge academia &amp; industry through AI-powered education, hands-on product building, and massive impact events touching <span className="font-semibold text-[#84ADFF]">9M+ people</span>.
              </p>

              {/* Highlights — staggered */}
              <div className="flex flex-col gap-3 mb-8">
                {[
                  { icon: <GraduationCap size={17} className="text-[#4361EE]" />, text: 'M.Tech CS (CGPA 7.6) & B.Tech CS (CGPA 7.5) — LPU', color: '#4361EE' },
                  { icon: <BrainCircuit size={17} className="text-[#7C3AED]" />,  text: 'Co-built TeachGenie — AI teaching platform at LPU',    color: '#7C3AED' },
                  { icon: <Building2  size={17} className="text-[#10B981]" />, text: 'NEP Sarthi Reform Officer, UGC — Govt. of India',       color: '#10B981' },
                  { icon: <Rocket     size={17} className="text-[#F59E0B]" />, text: 'Mentro — 50K+ downloads, Y Combinator Top 10%',        color: '#F59E0B' },
                  { icon: <Globe      size={17} className="text-[#4361EE]" />, text: 'Techfluence — 6 editions, 9M+ reach, 30+ leaders',      color: '#4361EE' },
                  { icon: <Sparkles   size={17} className="text-[#7C3AED]" />, text: 'Google Nebular Contributor · 6 Patents Filed',           color: '#7C3AED' },
                ].map((b, i) => (
                  <div
                    key={i}
                    className="flex items-center gap-3 glass-card rounded-2xl px-4 py-3.5 hover:-translate-y-0.5 transition-all duration-300 group animate-fadeUp"
                    style={{ animationDelay: `${0.15 + i * 0.08}s`, animationFillMode: 'both' }}
                  >
                    <div className="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform" style={{ background: b.color + '15' }}>
                      {b.icon}
