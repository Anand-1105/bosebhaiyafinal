export default function Home() {
  const [isScrolled, setIsScrolled] = useState(false);
  const [activeTab, setActiveTab] = useState('Theory Sessions');
  const [activeVideo, setActiveVideo] = useState(null);
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
  const [isMeetingModalOpen, setIsMeetingModalOpen] = useState(false);
  const [showAllComments, setShowAllComments] = useState(false);
  const [meetingForm, setMeetingForm] = useState({
    name: '',
    email: '',
    phone: '',
    date: '',
    message: '',
  });
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [submitSuccess, setSubmitSuccess] = useState(false);
  const [activeEdition, setActiveEdition] = useState(0);

  const handleMeetingFormChange = (e) => {
    setMeetingForm({ ...meetingForm, [e.target.name]: e.target.value });
  };

  const handleMeetingSubmit = async (e) => {
    e.preventDefault();
    setIsSubmitting(true);
    // TODO: Send to backend
    // await fetch('/api/schedule-meeting', { method: 'POST', body: JSON.stringify(meetingForm) });
    await new Promise(resolve => setTimeout(resolve, 1500)); // simulate API call
    setIsSubmitting(false);
    setSubmitSuccess(true);
    setTimeout(() => {
      setIsMeetingModalOpen(false);
      setSubmitSuccess(false);
      setMeetingForm({ name: '', email: '', phone: '', date: '', message: '' });
    }, 2000);
  };

  // Prevent scrolling when mobile menu or meeting modal is open
  useEffect(() => {
    if (isMobileMenuOpen || isMeetingModalOpen) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = 'unset';
    }
  }, [isMobileMenuOpen, isMeetingModalOpen]);

  const programTabs = [
    'Theory Sessions', 'AI Building Lab Sessions', 'Group Discussion Sessions', 'Recorded Sessions', 'Master Sessions'
  ];

  useEffect(() => {
    const handleScroll = () => {
      setIsScrolled(window.scrollY > 50);
    };

    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);
  return (
    <div className="min-h-screen font-sans antialiased relative overflow-hidden" style={{ background: '#000B21', color: '#E2E8F0' }}>

      {/* 
        ========================================
        NORMAL NAVBAR (Initial State)
        ========================================
      */}
      <nav className={`fixed top-0 left-0 right-0 z-50 py-5 px-6 md:px-10 max-w-[1400px] mx-auto flex justify-between items-center transition-all duration-300 ${isScrolled ? 'opacity-0 pointer-events-none' : 'opacity-100'}`}>
        <div className="font-bold tracking-tighter text-2xl flex flex-col leading-none">
          <span className="text-white">Subhardaya</span>
          <span className="font-serif italic text-sm text-white/60">Bose.</span>
        </div>

        {/* Desktop Links */}
        <div className="hidden lg:flex gap-6 text-[13px] font-medium text-white/80">
          <Link href="/content" className="hover:text-white transition-colors relative group">Content<div className="absolute -bottom-1 left-0 w-0 h-0.5 bg-white transition-all group-hover:w-full"></div></Link>
          <a href="#services" className="hover:text-white transition-colors relative group">Services<div className="absolute -bottom-1 left-0 w-0 h-0.5 bg-white transition-all group-hover:w-full"></div></a>
          <Link href="/patents" className="hover:text-white transition-colors relative group">Patents<div className="absolute -bottom-1 left-0 w-0 h-0.5 bg-white transition-all group-hover:w-full"></div></Link>
          <Link href="/research" className="hover:text-white transition-colors relative group">Research Papers<div className="absolute -bottom-1 left-0 w-0 h-0.5 bg-white transition-all group-hover:w-full"></div></Link>
          <Link href="/experience" className="hover:text-white transition-colors relative group">Experience<div className="absolute -bottom-1 left-0 w-0 h-0.5 bg-white transition-all group-hover:w-full"></div></Link>
        </div>

        {/* Desktop CTA */}
        <div className="hidden lg:flex items-center gap-3">
          <a href="/resume.pdf" download className="flex items-center gap-2 border border-white/30 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-white/10 transition-all">
            <Download size={14} /> Resume
          </a>
          <button onClick={() => setIsMeetingModalOpen(true)} className="px-6 py-2.5 rounded-full text-sm font-bold hover:scale-105 transition-all text-white" style={{ background: 'linear-gradient(135deg,#3D5BF1,#84ADFF)', boxShadow: '0 0 24px rgba(61,91,241,0.45)' }}>
            Schedule a Meeting
          </button>
        </div>

        {/* Mobile Menu Toggle */}
        <button
          className="lg:hidden p-2 text-white hover:bg-white/10 rounded-full transition-colors z-[110]"
          onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}
        >
          {isMobileMenuOpen ? <X size={24} /> : <Menu size={24} />}
        </button>
      </nav>

      {/* 
        ========================================
        FLOATING NAVBAR (Scrolled State)
        ========================================
      */}
      <div className={`fixed top-6 inset-x-0 z-[100] flex justify-center px-4 pointer-events-none transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] ${isScrolled ? 'opacity-100 translate-y-0' : 'opacity-0 -translate-y-8'}`}>
        <nav className={`rounded-full px-4 py-3 flex items-center justify-between shadow-[0_20px_40px_rgba(0,0,0,0.6)] border border-white/10 w-full max-w-[1100px] backdrop-blur-md transition-all ${isScrolled ? 'pointer-events-auto' : 'pointer-events-none'}`} style={{ background: 'rgba(0,11,33,0.85)', color: '#E2E8F0' }}>
          <div className="font-bold tracking-tighter text-xl flex flex-col leading-none pl-4 pr-6">
            <span>Subhardaya</span>
            <span className="font-serif italic text-[11px] text-[#EAEAE5]/60">Bose.</span>
          </div>

          <div className="hidden lg:flex gap-6 text-[13px] font-medium text-[#EAEAE5]/80">
            <Link href="/content" className="hover:text-white transition-colors">Content</Link>
            <a href="#services" className="hover:text-white transition-colors">Services</a>
            <Link href="/patents" className="hover:text-white transition-colors">Patents</Link>
            <Link href="/research" className="hover:text-white transition-colors">Research Papers</Link>
            <Link href="/experience" className="hover:text-white transition-colors">Experience</Link>
          </div>

          <div className="hidden lg:flex items-center gap-3">
            <a href="/resume.pdf" download className="flex border border-white/20 text-[#EAEAE5] px-4 py-2 rounded-full text-sm font-semibold hover:bg-white/10 transition-all">
              Resume
            </a>
            <button onClick={() => setIsMeetingModalOpen(true)} className="px-6 py-2.5 rounded-full text-sm font-bold hover:scale-105 transition-all text-white md:ml-2" style={{ background: 'linear-gradient(135deg,#3D5BF1,#84ADFF)', boxShadow: '0 0 20px rgba(61,91,241,0.4)' }}>
              Schedule Meeting
            </button>
          </div>

          {/* Mobile Menu Toggle for floating nav */}
          <button
            className="lg:hidden p-2 text-[#EAEAE5] hover:bg-white/10 rounded-full transition-colors"
            onClick={() => setIsMobileMenuOpen(true)}
          >
            <Menu size={24} />
          </button>
        </nav>
      </div>

      {/* 
        ========================================
        MOBILE MENU OVERLAY
        ========================================
      */}
      <div className={`fixed inset-0 bg-[#EAEAE5] z-[105] flex flex-col justify-center items-center transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] ${isMobileMenuOpen ? 'opacity-100 pointer-events-auto' : 'opacity-0 pointer-events-none'}`}>

        {/* Close Button styling matched to the dark floating navbar theme for contrast if needed, or keeping it dark on light */}
        <button
          className="absolute top-6 right-6 p-2 text-[#1A1A1A] bg-[#1A1A1A]/5 hover:bg-[#1A1A1A]/10 rounded-full transition-colors"
          onClick={() => setIsMobileMenuOpen(false)}
        >
          <X size={28} />
        </button>

        <div className="flex flex-col gap-6 text-center text-3xl font-black tracking-tight text-[#1A1A1A] w-full px-6">
          <Link href="/content" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-[#4361EE] hover:translate-x-2 transition-all">Content</Link>
          <a href="#services" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-[#4361EE] hover:translate-x-2 transition-all">Services</a>
          <Link href="/patents" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-[#4361EE] hover:translate-x-2 transition-all">Patents</Link>
          <Link href="/research" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-[#4361EE] hover:translate-x-2 transition-all">Research Papers</Link>
          <Link href="/experience" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-[#4361EE] hover:translate-x-2 transition-all">Experience</Link>
        </div>

        <div className="flex flex-col gap-4 mt-12 w-full px-12 max-w-sm">
          <a href="/resume.pdf" download className="flex items-center justify-center gap-2 border-2 border-[#1A1A1A] text-[#1A1A1A] px-6 py-4 rounded-full text-lg font-bold hover:bg-[#1A1A1A] hover:text-white transition-all w-full">
            <Download size={20} /> Download Resume
          </a>
          <button onClick={() => { setIsMobileMenuOpen(false); setIsMeetingModalOpen(true); }} className="bg-[#1A1A1A] text-white px-6 py-4 rounded-full text-lg font-bold shadow-[0_10px_30px_rgba(26,26,26,0.3)] hover:scale-105 transition-all w-full">
            Schedule a Meeting
          </button>
        </div>
      </div>

      {/* 
        ========================================
        SCHEDULE A MEETING MODAL
        ========================================
      */}
      {isMeetingModalOpen && (
        <div className="fixed inset-0 z-[200] flex items-center justify-center p-4">
          {/* Backdrop */}
          <div
            className="absolute inset-0 bg-black/60 backdrop-blur-sm"
            onClick={() => { setIsMeetingModalOpen(false); setSubmitSuccess(false); }}
          />

          {/* Modal Card */}
          <div className="relative bg-[#EAEAE5] rounded-[2rem] w-full max-w-lg max-h-[90vh] overflow-y-auto shadow-[0_30px_80px_rgba(0,0,0,0.5)] border border-white/20 animate-[modalSlideIn_0.4s_ease-out]">

            {/* Top Accent Bar */}
            <div className="h-1.5 w-full bg-gradient-to-r from-[#1A1A1A] via-[#4361EE] to-[#1A1A1A] rounded-t-[2rem]" />

            {/* Close Button */}
            <button
              onClick={() => { setIsMeetingModalOpen(false); setSubmitSuccess(false); }}
              className="absolute top-5 right-5 p-2 bg-[#1A1A1A]/5 hover:bg-[#1A1A1A]/10 rounded-full transition-colors text-[#1A1A1A]"
            >
              <X size={20} />
            </button>

            <div className="p-8 pt-6">
              {/* Header */}
              <div className="mb-8">
                <div className="flex items-center gap-3 mb-3">
                  <div className="w-10 h-10 rounded-full bg-[#1A1A1A] flex items-center justify-center">
                    <Calendar size={18} className="text-[#EAEAE5]" />
                  </div>
                  <h3 className="text-2xl font-black tracking-tight text-[#1A1A1A]">Schedule a Meeting</h3>
                </div>
                <p className="text-gray-600 text-sm leading-relaxed">Fill in your details and I'll get back to you within 24 hours to confirm the meeting.</p>
              </div>

              {submitSuccess ? (
                <div className="flex flex-col items-center justify-center py-12 text-center">
                  <div className="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mb-4">
                    <CheckCircle2 size={32} className="text-green-600" />
                  </div>
                  <h4 className="text-xl font-bold text-[#1A1A1A] mb-2">Request Sent!</h4>
                  <p className="text-gray-600 text-sm">Thank you! I'll reach out to confirm your meeting shortly.</p>
                </div>
              ) : (
                <form onSubmit={handleMeetingSubmit} className="flex flex-col gap-5">
                  {/* Name */}
                  <div className="relative">
                    <label className="text-[11px] font-bold uppercase tracking-widest text-gray-500 mb-1.5 block">Full Name</label>
                    <div className="relative">
                      <User size={16} className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" />
                      <input
                        type="text"
                        name="name"
                        value={meetingForm.name}
                        onChange={handleMeetingFormChange}
                        required
                        placeholder="Your full name"
                        className="w-full bg-white border border-black/10 rounded-xl py-3 pl-11 pr-4 text-sm text-[#1A1A1A] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1A1A1A]/20 focus:border-[#1A1A1A]/30 transition-all"
                      />
                    </div>
                  </div>

                  {/* Email */}
                  <div className="relative">
                    <label className="text-[11px] font-bold uppercase tracking-widest text-gray-500 mb-1.5 block">Email Address</label>
                    <div className="relative">
                      <Mail size={16} className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" />
                      <input
                        type="email"
                        name="email"
                        value={meetingForm.email}
                        onChange={handleMeetingFormChange}
                        required
                        placeholder="you@example.com"
                        className="w-full bg-white border border-black/10 rounded-xl py-3 pl-11 pr-4 text-sm text-[#1A1A1A] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1A1A1A]/20 focus:border-[#1A1A1A]/30 transition-all"
                      />
                    </div>
                  </div>

                  {/* Phone */}
                  <div className="relative">
                    <label className="text-[11px] font-bold uppercase tracking-widest text-gray-500 mb-1.5 block">Phone Number</label>
                    <div className="relative">
                      <Phone size={16} className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" />
                      <input
                        type="tel"
                        name="phone"
                        value={meetingForm.phone}
                        onChange={handleMeetingFormChange}
                        required
                        placeholder="+91 98765 43210"
                        className="w-full bg-white border border-black/10 rounded-xl py-3 pl-11 pr-4 text-sm text-[#1A1A1A] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1A1A1A]/20 focus:border-[#1A1A1A]/30 transition-all"
                      />
                    </div>
                  </div>

                  {/* Preferred Date */}
                  <div className="relative">
                    <label className="text-[11px] font-bold uppercase tracking-widest text-gray-500 mb-1.5 block">Preferred Date</label>
                    <div className="relative">
                      <CalendarDays size={16} className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" />
                      <input
                        type="date"
                        name="date"
                        value={meetingForm.date}
                        onChange={handleMeetingFormChange}
                        required
                        className="w-full bg-white border border-black/10 rounded-xl py-3 pl-11 pr-4 text-sm text-[#1A1A1A] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1A1A1A]/20 focus:border-[#1A1A1A]/30 transition-all"
                      />
                    </div>
                  </div>

                  {/* Message */}
                  <div className="relative">
                    <label className="text-[11px] font-bold uppercase tracking-widest text-gray-500 mb-1.5 block">Message / Topic</label>
                    <div className="relative">
                      <MessageSquare size={16} className="absolute left-4 top-4 text-gray-400" />
                      <textarea
                        name="message"
                        value={meetingForm.message}
                        onChange={handleMeetingFormChange}
                        rows={3}
                        placeholder="What would you like to discuss?"
                        className="w-full bg-white border border-black/10 rounded-xl py-3 pl-11 pr-4 text-sm text-[#1A1A1A] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1A1A1A]/20 focus:border-[#1A1A1A]/30 transition-all resize-none"
                      />
                    </div>
                  </div>

                  {/* Submit Button */}
                  <button
                    type="submit"
                    disabled={isSubmitting}
                    className="flex items-center justify-center gap-2 bg-[#1A1A1A] text-white py-4 rounded-xl text-sm font-bold shadow-[0_10px_30px_rgba(26,26,26,0.3)] hover:shadow-[0_15px_40px_rgba(26,26,26,0.4)] hover:-translate-y-0.5 transition-all disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:translate-y-0"
                  >
                    {isSubmitting ? (
                      <div className="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin" />
                    ) : (
                      <><Send size={16} /> Send Meeting Request</>
                    )}
                  </button>
                </form>
              )}
            </div>
          </div>
        </div>
      )}

      <style jsx>{`
        @keyframes modalSlideIn {
          from {
            opacity: 0;
            transform: scale(0.95) translateY(20px);
          }
          to {
            opacity: 1;
            transform: scale(1) translateY(0);
          }
        }
      `}</style>

      {/* 
        ========================================
        MAIN HERO SECTION — Full-Screen Video Background
        ========================================
      */}
      <section className="relative w-full min-h-screen flex flex-col justify-center items-center overflow-hidden" style={{ borderBottomLeftRadius: '50px', borderBottomRightRadius: '50px' }}>

        {/* ── Looping Background Video ── */}
        <video
          autoPlay
          loop
          muted
          playsInline
          className="absolute inset-0 w-full h-full object-cover z-0"
          src="/homepage.mp4"
        />

        {/* ── Dark cinematic gradient overlay ── */}
        <div className="absolute inset-0 z-10 bg-gradient-to-b from-black/70 via-black/50 to-black/80" />

        {/* ── Subtle vignette corners ── */}
        <div className="absolute inset-0 z-10 pointer-events-none" style={{ background: 'radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.6) 100%)' }} />

        {/* ── Hero Content ── */}
        <main className="relative z-20 w-full max-w-[1400px] mx-auto px-6 md:px-10 pt-32 pb-24 flex flex-col items-center text-center">

          {/* Live badge — Rethink-style blue gradient pill */}
          <div className="inline-flex items-center gap-2 rounded-full px-6 py-2.5 mb-8 text-white text-sm font-semibold" style={{ background: 'linear-gradient(180deg,rgba(0,0,0,0.25) 2%,rgba(18,62,151,0.35) 49%,rgba(100,137,212,0.25) 100%)', boxShadow: '0 1px 2px rgba(0,42,254,0.12), inset 0 0 10px rgba(255,255,255,0.12)', border: '1px solid rgba(132,173,255,0.2)' }}>
            <span className="w-2 h-2 rounded-full bg-[#84ADFF] animate-pulse"></span>
            Professor · Builder · Community Leader
          </div>

          {/* Headline — mixed weight Rethink style */}
          <h1 className="leading-[1.05] tracking-tight mb-6 text-white drop-shadow-2xl max-w-5xl" style={{ fontSize: 'clamp(2.5rem,5vw,5rem)', fontWeight: 300 }}>
            Souhardya <span style={{ fontWeight: 700 }}>Bose</span>
            <span className="block mt-1" style={{ fontWeight: 300 }}>Professor. Builder. <span className="blue-grad-text" style={{ fontWeight: 700 }}>Leader.</span></span>
          </h1>

          {/* Subheadline */}
          <p className="text-[17px] md:text-xl text-white/70 mb-12 max-w-2xl leading-relaxed">
            Assistant Professor &amp; Head of Student Success at LPU. Founder of Techfluence — 6 editions, 9M+ reach, 30+ global leaders. Building AI-powered futures.
          </p>

          {/* CTA Buttons — Rethink pill style */}
          <div className="flex flex-col sm:flex-row gap-4 mb-14">
            <a href="/resume.pdf" download className="flex items-center justify-center gap-2 border border-white/25 bg-white/8 backdrop-blur-sm text-white px-8 py-4 rounded-full text-[15px] font-semibold hover:bg-white/15 transition-all hover:-translate-y-0.5">
              <Download size={18} /> Download Resume
            </a>
            <button onClick={() => setIsMeetingModalOpen(true)} className="flex items-center justify-center gap-2 px-10 py-4 rounded-full text-[15px] font-bold text-white hover:-translate-y-0.5 transition-all" style={{ background: 'linear-gradient(135deg,#3D5BF1,#4179EA)', boxShadow: '0 0 40px rgba(61,91,241,0.5)' }}>
              Schedule a Meeting <ArrowRight size={17} />
            </button>
          </div>

          {/* Student avatars + count */}
          <div className="flex items-center gap-4">
            <div className="flex -space-x-3">
              <img src="/img/gallery/1.jpeg" alt="Student" className="w-10 h-10 rounded-full border-2 border-white/50 object-cover" />
              <img src="/img/gallery/2.jpeg" alt="Student" className="w-10 h-10 rounded-full border-2 border-white/50 object-cover" />
              <img src="/img/gallery/3.jpeg" alt="Student" className="w-10 h-10 rounded-full border-2 border-white/50 object-cover" />
              <img src="/img/gallery/4.jpeg" alt="Student" className="w-10 h-10 rounded-full border-2 border-white/50 object-cover" />
              <div className="w-10 h-10 rounded-full border-2 border-white/50 bg-white/20 backdrop-blur-sm text-white flex justify-center items-center text-xs font-bold">+</div>
            </div>
            <span className="text-[15px] font-bold tracking-tight text-white/90">1.6K+ students applied</span>
          </div>

          {/* Floating Glass Stats Row */}
          <div className="mt-16 flex flex-wrap justify-center gap-4">
            {/* YouTube */}
            <div className="bg-white/10 backdrop-blur-xl border border-white/20 px-5 py-3 rounded-full flex items-center gap-3 shadow-lg hover:bg-white/20 transition-all">
              <div className="bg-[#FF0000] w-8 h-8 rounded-full flex items-center justify-center shrink-0">
                <Youtube size={16} className="text-white fill-current" />
              </div>
              <div className="flex flex-col">
                <span className="text-sm font-bold text-white leading-none">45k+</span>
                <span className="text-[10px] text-white/60 uppercase tracking-widest font-semibold">YouTube Subs</span>
              </div>
            </div>

            {/* LinkedIn */}
            <div className="bg-white/10 backdrop-blur-xl border border-white/20 px-5 py-3 rounded-full flex items-center gap-3 shadow-lg hover:bg-white/20 transition-all">
              <div className="bg-[#0A66C2] w-8 h-8 rounded-full flex items-center justify-center shrink-0">
                <Linkedin size={16} className="text-white fill-current" />
              </div>
              <div className="flex flex-col">
                <span className="text-sm font-bold text-white leading-none">194k+</span>
                <span className="text-[10px] text-white/60 uppercase tracking-widest font-semibold">LinkedIn Followers</span>
              </div>
            </div>

            {/* Name plate */}
            <div className="bg-white/10 backdrop-blur-xl border border-white/20 px-5 py-3 rounded-full flex items-center gap-3 shadow-lg hover:bg-white/20 transition-all">
              <div className="w-8 h-8 rounded-full overflow-hidden shrink-0 border border-white/30">
                <img src="/img/gallery/6.jpeg" alt="Avatar" className="w-full h-full object-cover" />
              </div>
              <div className="flex flex-col">
                <span className="text-sm font-bold text-white leading-none">Subhardaya Bose</span>
                <span className="text-[10px] text-white/60 uppercase tracking-widest font-semibold">Program Director</span>
              </div>
            </div>
          </div>
        </main>

        {/* ── Recognitions marquee strip at bottom ── */}
        <div className="absolute bottom-0 left-0 right-0 z-20 py-4 mask-marquee overflow-hidden" style={{ background: 'rgba(0,0,0,0.35)', backdropFilter: 'blur(8px)', borderTop: '1px solid rgba(255,255,255,0.06)' }}>
          <div className="flex gap-10 animate-marquee whitespace-nowrap" style={{ width: 'max-content' }}>
            {['🎓 LPU — Lovely Professional University', '🧪 Google Nebular Contributor', '🏆 Y Combinator Top 10%', '🏛️ UGC — Govt. of India', '📡 9M+ Community Reach', '📋 6 Patents Filed', '🌐 NASSCOM Community', '🎓 LPU — Lovely Professional University', '🧪 Google Nebular Contributor', '🏆 Y Combinator Top 10%', '🏛️ UGC — Govt. of India', '📡 9M+ Community Reach', '📋 6 Patents Filed', '🌐 NASSCOM Community'].map((label, i) => (
              <span key={i} className="text-white/50 text-xs font-semibold uppercase tracking-widest">{label}</span>
            ))}
          </div>
        </div>
      </section>

      {/* ═══════════════════════════════
          SECTION 6 — TECHFLUENCE (Blue Theme) — Detailed Season View
      ═══════════════════════════════ */}
      <section id="techfluence" className="w-full py-28 px-6 md:px-10" style={{ background: '#050E24' }}>
        <div className="max-w-[1200px] mx-auto">
          {/* Header */}
          <div className="text-center mb-16">
            <div className="section-badge mb-6 mx-auto bg-white/5 border-white/10 text-white/70"><Globe size={12} /> Flagship Series</div>
            <h2 className="text-4xl md:text-6xl tracking-tight text-white mb-4" style={{ fontWeight: 300 }}>Techfluence <span style={{ fontWeight: 700 }} className="text-white/70">6 Seasons</span></h2>
            <p className="text-white/50 max-w-xl mx-auto text-base">India&apos;s most impactful university-led tech community event series — 9M+ cumulative reach, 30+ global leaders.</p>
          </div>

          {/* ── Season Tabs ── */}
          <div className="flex flex-wrap justify-center gap-3 mb-12">
            {TECHFLUENCE.map((ev, i) => (
              <button
                key={i}
                onClick={() => setActiveEdition(i)}
                className={`px-5 py-2.5 rounded-full text-sm font-semibold border transition-all duration-300 ${
                  activeEdition === i
                    ? 'text-black bg-white scale-105 border-transparent'
                    : 'bg-transparent text-white/50 border-white/15 hover:border-white/30 hover:text-white/80'
                }`}
              >
                Season {ev.edition}
              </button>
            ))}
          </div>

          {/* ── Active Season Detail View ── */}
          {(() => {
            const ev = TECHFLUENCE[activeEdition];
            return (
              <div key={activeEdition} className="animate-fadeUp">
                {/* Hero Banner for the Edition */}
                <div className="relative rounded-[2rem] overflow-hidden mb-10 border border-white/10">
                  <div className="aspect-[21/9] md:aspect-[3/1] relative overflow-hidden bg-black">
                    <img src={ev.img} alt={ev.title} className="w-full h-full object-cover opacity-80" />
                    <div className="absolute inset-0 bg-gradient-to-r from-[#0B1221] via-[#0B1221]/80 to-transparent" />
                    <div className="absolute inset-0 flex flex-col justify-center p-8 md:p-14">
                      <div className="flex gap-2 mb-4">
                        <span className="bg-white/10 text-white/90 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest border border-white/10">Season {ev.edition}</span>
                        <span className="bg-white/5 backdrop-blur text-white/60 text-[10px] font-bold px-3 py-1 rounded-full border border-white/10">{ev.date}</span>
                      </div>
                      <h3 className="text-3xl md:text-5xl font-black text-white leading-tight mb-3">{ev.title}</h3>
                      <p className="text-white/60 max-w-xl text-sm md:text-base leading-relaxed">{ev.desc}</p>
                      <div className="flex gap-6 mt-6">
                        <div>
                          <div className="text-2xl md:text-3xl font-black text-white">{ev.reach}</div>
                          <div className="text-[9px] text-white/40 uppercase tracking-widest font-bold">Reach</div>
                        </div>
                        <div>
                          <div className="text-2xl md:text-3xl font-black text-white">{ev.attendees}</div>
                          <div className="text-[9px] text-white/40 uppercase tracking-widest font-bold">Attendees</div>
                        </div>
                        <div>
                          <div className="text-2xl md:text-3xl font-black text-white">{ev.guests.length}+</div>
                          <div className="text-[9px] text-white/40 uppercase tracking-widest font-bold">Speaker Groups</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Detail Grid: Guests + Souhardya + Comments */}
                {/* Detail Grid: Guests + Souhardya + Comments */}
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">

                  {/* Guest Speakers Card */}
                  <div className="rounded-[2rem] border border-white/10 overflow-hidden hover:-translate-y-1 transition-all duration-300 bg-white/5">
                    <div className="p-7">
                      <div className="flex items-center gap-3 mb-5">
                        <div className="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center border border-white/10">
                          <Users size={18} className="text-white/80" />
                        </div>
                        <h4 className="text-lg font-black text-white">Guest Speakers</h4>
                      </div>
                      <div className="space-y-3">
                        {ev.guests.map((g, j) => (
                          <div key={j} className="flex items-center gap-3 hover:translate-x-1 transition-transform">
                            <div className="w-10 h-10 rounded-full overflow-hidden border border-white/15 shrink-0">
                              <img src={`/img/gallery/${(j + 1 + activeEdition * 3) % 20 + 1}.jpeg`} alt={g} className="w-full h-full object-cover" />
                            </div>
                            <div>
                              <div className="text-white text-sm font-bold">{g}</div>
                              <div className="text-white/30 text-[10px] uppercase tracking-widest">Season {ev.edition} Speaker</div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>

                  {/* Souhardya's Contribution Card */}
                  <div className="rounded-[2rem] border border-white/10 overflow-hidden hover:-translate-y-1 transition-all duration-300 bg-white/5">
                    <div className="h-40 relative overflow-hidden">
                      <img src={`/img/gallery/${activeEdition + 6}.jpeg`} alt="Souhardya Bose" className="w-full h-full object-cover opacity-60" />
                      <div className="absolute inset-0 bg-gradient-to-t from-[#0B1221] to-transparent" />
                      <div className="absolute bottom-4 left-6 flex items-center gap-3">
                        <div className="w-10 h-10 rounded-full overflow-hidden border border-white/20">
                          <img src="/img/gallery/6.jpeg" alt="Souhardya" className="w-full h-full object-cover" />
                        </div>
                        <div>
                          <div className="text-white font-black text-sm">Souhardya Bose</div>
                          <div className="text-white/50 text-[10px] font-bold uppercase tracking-widest">Founder & Director</div>
                        </div>
                      </div>
                    </div>
                    <div className="p-6">
                      <h4 className="text-base font-black text-white mb-3">Contributions</h4>
                      <ul className="space-y-2">
                        {[
                          'Curated & invited all keynote speakers',
                          'Led end-to-end event strategy & execution',
                          'Delivered opening keynote address',
                          'Mentored student organizers & volunteers',
                        ].map((c, j) => (
                          <li key={j} className="flex items-start gap-2 text-[13px] text-white/60">
                            <CheckCircle2 size={14} className="text-white/40 shrink-0 mt-0.5" />
                            {c}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>

                  {/* Social Media Comments Card */}
                  <div className="rounded-[2rem] border border-white/10 overflow-hidden hover:-translate-y-1 transition-all duration-300 bg-white/5">
                    <div className="p-7">
                      <div className="flex items-center gap-3 mb-5">
                        <div className="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center border border-white/10">
                          <MessageSquare size={18} className="text-white/80" />
                        </div>
                        <h4 className="text-lg font-black text-white">What People Said</h4>
                      </div>
                      <div className="space-y-4">
                        {ev.comments.map((c, j) => (
                          <div key={j} className="rounded-xl p-4 border border-white/8 hover:border-white/15 transition-all bg-white/5">
                            <div className="flex items-center gap-1 mb-2">
                              {[...Array(5)].map((_, k) => <Star key={k} size={10} className="fill-white/40 text-white/40" />)}
                            </div>
                            <p className="text-white/70 text-[13px] italic leading-relaxed mb-3">&ldquo;{c.text}&rdquo;</p>
                            <div className="flex items-center gap-2">
                              <div className="w-7 h-7 rounded-full overflow-hidden border border-white/15">
                                <img src={`/img/gallery/${(j + 1 + activeEdition * 2) % 20 + 1}.jpeg`} alt={c.name} className="w-full h-full object-cover" />
                              </div>
                              <div>
                                <div className="text-white text-xs font-bold">{c.name}</div>
                                <div className="text-white/30 text-[10px]">{c.role}</div>
                              </div>
                              <Linkedin size={12} className="text-white/30 ml-auto" />
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                {/* Event Photo Gallery Strip */}
                <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                  {[1, 2, 3, 4].map(offset => {
                    const imgIdx = ((activeEdition * 4 + offset) % 10) + 1;
                    return (
                      <div key={offset} className="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 group">
                        <img src={`/img/carousel/${imgIdx}.jpeg`} alt={`Techfluence Season ${TECHFLUENCE[activeEdition].edition} - Photo ${offset}`} className="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })()}
        </div>
      </section>

      {/* ═══════════════════════════════
          SECTION 4 — STARTUPS 
      ═══════════════════════════════ */}
      <section id="startups" className="w-full py-32 px-6 md:px-10 relative overflow-hidden" style={{ background: '#050E24' }}>
        <div className="max-w-[1300px] mx-auto relative z-10">
          
          {/* Header - Matching screenshot exactly */}
          <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 animate-fadeUp gap-6">
            <h2 className="text-4xl md:text-[44px] font-medium tracking-tight text-white/90">
              Startups <span className="text-white/60">I&apos;ve Built in the AI era?</span>
            </h2>
            <a href="#experience" className="px-6 py-2.5 rounded-full text-[15px] font-bold text-white transition-all shadow-[0_0_20px_rgba(59,130,246,0.3)] hover:shadow-[0_0_30px_rgba(59,130,246,0.5)] whitespace-nowrap" style={{ background: 'linear-gradient(135deg, #3B82F6 0%, #2563EB 100%)' }}>
              View All Ventures
            </a>
          </div>

          {/* Cards Grid */}
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            {STARTUPS.map((s, i) => (
              <div 
                key={i} 
                className="group relative rounded-[2rem] border overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)] animate-fadeUp flex flex-col h-[520px]" 
                style={{ 
                  animationDelay: `${i * 0.15}s`, 
                  animationFillMode: 'both',
                  background: '#0B1221',
                  borderColor: 'rgba(255,255,255,0.06)'
                }}
              >
                {/* Specific top-right dark radial glow matching screenshot */}
                <div 
                  className="absolute top-0 right-0 w-[120%] h-[120%] pointer-events-none opacity-80" 
                  style={{ background: `radial-gradient(circle at 100% 0%, ${s.color}20 0%, transparent 60%)` }} 
                />

                {/* Content Section (Top Half) */}
                <div className="relative z-20 px-8 pt-10 flex-1">
                  <h3 className="text-[22px] font-semibold text-white/95 leading-tight tracking-tight mb-4 group-hover:text-white transition-colors duration-300">
                    {s.name}
                  </h3>
                  
                  <p className="text-[15px] text-white/70 italic leading-relaxed" style={{ fontFamily: 'Georgia, Cambria, "Times New Roman", Times, serif' }}>
                    &quot;{s.desc}&quot;
                  </p>

                  <div className="mt-8 flex flex-wrap items-center justify-between gap-3">
                    <div className="flex items-center gap-2 text-[13px] text-white/50 tracking-wide">
                      <span className="w-4 h-px bg-white/30 block"></span>
                      {s.role}
                    </div>
                    <div className="font-bold text-sm tracking-wide flex items-center gap-1.5" style={{ color: s.color }}>
                      <span className="text-[16px] leading-none mb-0.5">{s.icon}</span> {s.status}
                    </div>
                  </div>
                </div>

                {/* Bottom Graphic / Image Area */}
                <div className="relative h-56 w-full mt-auto">
                  <div className="absolute inset-0 bg-gradient-to-b from-[#0B1221] via-[#0B1221]/40 to-transparent z-10" />
                  <img 
                    src={s.img} 
                    alt={s.name} 
                    className="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-700" 
                  />
                  
                  {/* Floating Stats simulating UI elements from screenshot */}
                  <div className="absolute inset-0 z-20 flex items-end justify-center pb-8 px-6 gap-2 opacity-90">
                    {s.metrics.map((m, j) => (
                      <div 
                        key={j} 
                        className="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-3 flex-1 flex flex-col items-center justify-center shadow-lg group-hover:-translate-y-1 transition-transform"
                        style={{ transitionDelay: `${j * 50}ms` }}
                      >
                        <div className="text-[17px] font-black text-white leading-tight">{m.v}</div>
                        <div className="text-[9px] text-white/40 uppercase tracking-widest font-semibold mt-1">{m.l}</div>
                      </div>
                    ))}
                  </div>
                </div>

              </div>
            ))}
          </div>

        </div>
      </section>

      {/* ═══════════════════════════════
          SECTION 2 — ABOUT  (Rethink-style dark navy + glassmorphism)
      ═══════════════════════════════ */}
      <section id="about" className="w-full py-28 px-6 md:px-10 relative overflow-hidden" style={{ background: '#050E24' }}>

        {/* Blue radial glow blobs — Rethink style */}
        <div className="absolute top-[-20%] right-[-10%] w-[700px] h-[700px] rounded-full pointer-events-none z-0" style={{ background: 'radial-gradient(circle, rgba(61,91,241,0.12) 0%, transparent 70%)' }} />
        <div className="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] rounded-full pointer-events-none z-0" style={{ background: 'radial-gradient(circle, rgba(65,121,234,0.08) 0%, transparent 70%)' }} />

        <div className="max-w-[1280px] mx-auto relative z-10 pt-12 pb-20">

          {/* ── Section label row ── */}
          <div className="flex items-center gap-4 mb-14 animate-fadeUp">
            <div className="section-badge">
              <User size={12} /> About Me
            </div>
            <span className="h-px flex-1" style={{ background: 'linear-gradient(to right, rgba(61,91,241,0.3), transparent)' }} />
            <span className="text-xs font-bold text-white/30 uppercase tracking-widest hidden md:block">LPU · Class of 2025</span>
          </div>

          {/* ── MAIN 3-column grid: LEFT photos | CENTRE bio | RIGHT stats ── */}
