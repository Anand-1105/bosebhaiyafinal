                  <MapPin size={12} className="text-[#84ADFF]" /> Punjab, India
                </div>
                <div className="glass-card px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 animate-float text-white" style={{ animationDelay: '0.8s' }}>
                  <Linkedin size={12} className="text-[#0A66C2]" /> 194K+ LinkedIn
                </div>
                <div className="glass-card px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 animate-float text-white" style={{ animationDelay: '1.6s' }}>
