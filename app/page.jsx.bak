                    <p className="text-white/70 text-sm font-medium">{b.text}</p>
                    <ArrowRight size={14} className="text-white/20 ml-auto shrink-0 group-hover:text-white/60 group-hover:translate-x-0.5 transition-all" />
                  </div>
                ))}
              </div>

              {/* Dual CTA */}
              <div className="flex flex-wrap gap-3">
                <a href="/resume.pdf" download className="flex items-center gap-2 bg-[#1A1A1A] text-white px-6 py-3 rounded-full text-sm font-bold shadow-md hover:-translate-y-0.5 hover:shadow-lg transition-all">
                  <Download size={15} /> Download Resume
                </a>
                <a href="https://linkedin.com" target="_blank" rel="noreferrer" className="flex items-center gap-2 bg-white text-[#1A1A1A] px-6 py-3 rounded-full text-sm font-bold border border-black/10 shadow-sm hover:-translate-y-0.5 hover:shadow-md transition-all">
                  <Linkedin size={15} className="text-[#0A66C2]" /> LinkedIn
                </a>
              </div>
            </div>

            {/* RIGHT: Stats + quick identity cards */}
            <div className="flex flex-col gap-4 animate-slideRight" style={{ animationFillMode: 'both', animationDelay: '0.2s' }}>

              {/* 4 stat cards */}
              {STATS.map((s, i) => {
                const colors = ['#4361EE', '#7C3AED', '#10B981', '#F59E0B'];
                const icons  = [
                  <Lightbulb size={20} key={0} style={{ color: colors[0] }} />,
                  <BookOpen  size={20} key={1} style={{ color: colors[1] }} />,
                  <GraduationCap size={20} key={2} style={{ color: colors[2] }} />,
                  <TrendingUp size={20} key={3} style={{ color: colors[3] }} />,
                ];
                return (
                  <div
                    key={s.label}
                    className="glass-card rounded-2xl p-5 hover:-translate-y-1 transition-all duration-300 flex items-center gap-4 group animate-fadeUp"
                    style={{ animationDelay: `${0.2 + i * 0.1}s`, animationFillMode: 'both' }}
                  >
                    <div className="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform" style={{ background: colors[i] + '15' }}>
                      {icons[i]}
                    </div>
                    <div>
                      <div className="text-2xl font-bold text-white">{s.value}</div>
                      <div className="text-[10px] font-bold uppercase tracking-widest text-white/40">{s.label}</div>
                    </div>
                  </div>
                );
              })}

              {/* Role identity pills */}
              <div className="glass-card rounded-2xl p-5">
                <p className="text-[10px] font-bold uppercase tracking-widest text-white/40 mb-3">I&apos;m also a</p>
                <div className="flex flex-wrap gap-2">
                  {['🎤 Speaker', '🧑‍🏫 Teacher', '📲 Influencer', '🚀 Founder', '🏛️ Policy Advisor', '🤖 AI Builder'].map(tag => (
                    <span key={tag} className="glass-card text-white/70 text-xs font-semibold px-3 py-1.5 rounded-full hover:text-white transition-all cursor-default">{tag}</span>
                  ))}
                </div>
              </div>

              {/* Education block */}
              <div className="glass-card rounded-2xl p-5">
                <p className="text-[10px] font-bold uppercase tracking-widest text-white/40 mb-3">Education</p>
                <div className="space-y-3">
                  <div className="flex items-start gap-3">
                    <div className="w-8 h-8 rounded-lg bg-[#4361EE]/20 flex items-center justify-center shrink-0 mt-0.5">
                      <GraduationCap size={15} className="text-[#4361EE]" />
                    </div>
                    <div>
                      <div className="font-bold text-sm">M.Tech — CSE</div>
                      <div className="text-white/40 text-xs">LPU · 2023–25 · CGPA 7.6</div>
                    </div>
                  </div>
                  <div className="flex items-start gap-3">
                    <div className="w-8 h-8 rounded-lg bg-[#7C3AED]/20 flex items-center justify-center shrink-0 mt-0.5">
                      <BookOpen size={15} className="text-[#7C3AED]" />
                    </div>
                    <div>
                      <div className="font-bold text-sm">B.Tech — CSE</div>
                      <div className="text-white/40 text-xs">LPU · 2019–23 · CGPA 7.5</div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

      </section>




      {/* ═══════════════════════════════
          SECTION 3 — EXPERIENCE (Dark Timeline)
      ═══════════════════════════════ */}
      {/* Top transition — smooth dark blend */}
      <div className="w-full h-32 pointer-events-none" style={{ background: 'linear-gradient(to bottom, #030816, #050E24)' }} />

      <section id="experience" className="w-full pb-28 px-6 md:px-10 relative overflow-hidden" style={{ background: '#050E24' }}>
        
        {/* Subtle dot-grid for structure */}
        <div
          className="absolute inset-0 opacity-[0.03] z-0 pointer-events-none"
          style={{ backgroundImage: 'radial-gradient(circle, #ffffff 1px, transparent 1px)', backgroundSize: '32px 32px' }}
        />

        <div className="max-w-[1200px] mx-auto relative z-10">
          <div className="flex flex-col items-center text-center gap-4 mb-24 animate-fadeUp">
            <div className="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 mb-2">
              <Zap size={14} className="text-white/60" />
              <span className="text-[10px] font-bold uppercase tracking-widest text-white/60">Career History</span>
            </div>
            <h2 className="text-5xl md:text-7xl font-black tracking-tighter text-white leading-[1.02] mb-4">
              Work <span className="text-white/80">Experience</span>
            </h2>
            <p className="text-white/40 max-w-xl mx-auto text-base">A journey through my professional roles, delivering impact and building scalable real-world products.</p>
          </div>
          
          <div className="relative before:absolute before:inset-0 before:ml-3 md:before:mx-auto md:before:translate-x-0 before:h-full before:w-px before:bg-gradient-to-b before:from-transparent before:via-white/10 before:to-transparent">
            {EXPERIENCE.map((e, i) => (
              <div key={i} className={`relative flex items-center mb-16 last:mb-0 animate-fadeUp ${i % 2 === 0 ? 'md:justify-start' : 'md:justify-end'}`} style={{ animationDelay: `${i * 0.1}s`, animationFillMode: 'both' }}>
                
                {/* Timeline Node - pushed tighter left on mobile */}
                <div className="absolute left-3 md:left-1/2 transform -translate-x-1/2 flex items-center justify-center w-6 h-6 md:w-8 md:h-8 rounded-full border-[3px] md:border-4 border-[#050E24] shadow-[0_0_20px_rgba(0,0,0,0.5)] z-20 group-hover:scale-[1.2] transition-transform duration-500 bg-white/10">
                  <div className="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-white opacity-80" />
                </div>
                
                {/* Experience Card - Wider on mobile, reduced border radius to avoid squishing content */}
                <div className="w-[calc(100%-2.5rem)] ml-auto md:ml-0 md:w-[calc(50%-4rem)] rounded-2xl md:rounded-[2rem] border border-white/5 bg-[#000B21] transition-all duration-700 hover:-translate-y-2 hover:shadow-[0_20px_50px_rgba(0,0,0,0.3)] hover:border-white/15 relative overflow-hidden group">
                  
                  {/* Subtle top glow matching brand */}
                  <div className="absolute top-0 left-0 w-full h-[1px] opacity-40 group-hover:opacity-100 transition-opacity z-30" style={{ background: `linear-gradient(90deg,transparent,${e.color},transparent)` }} />
                  
                  {/* Embedded Rich Image Header using the "Clear Area" */}
                  <div className="h-40 md:h-48 w-full relative overflow-hidden border-b border-white/5">
                    {/* Removed heavy blackout overlay so images are super clear */}
                    <img src={e.img} alt={e.role} className="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" />
                    {/* Keep only a smooth gradient at the bottom so it fades into the card */}
                    <div className="absolute inset-0 z-20" style={{ background: 'linear-gradient(to bottom, transparent 30%, #000B21 100%)' }} />
                  </div>

                  <div className="p-5 md:p-8 relative z-30 -mt-6 md:-mt-8">
                    <div className="flex flex-col md:flex-row md:items-center justify-between gap-3 mb-4 md:mb-5">
                      <div className="inline-flex px-3 py-1.5 rounded-full text-[9px] md:text-[10px] font-black uppercase tracking-widest border border-white/10 bg-[#000B21] text-white/70 items-center gap-1.5 shadow-lg w-fit">
                        <CalendarDays size={12} className="opacity-50" />
                        {e.period}
                      </div>
                    </div>
                    
                    <h3 className="text-lg md:text-2xl font-black text-white mb-2 tracking-tight group-hover:text-white/90 transition-colors" style={{ letterSpacing: '-0.02em' }}>{e.role}</h3>
                    <div className="text-[12px] md:text-[13px] font-bold mb-4 md:mb-6 flex items-center gap-2 text-white/40 uppercase tracking-widest">
                      <span className="text-base md:text-lg opacity-60 mix-blend-luminosity shrink-0">{['🏫', '💡', '🏛️', '🛡️', '🤝'][i]}</span> 
                      <span className="truncate whitespace-normal">{e.org}</span>
                    </div>
                    
                    <ul className="space-y-3">
                      {e.bullets.map((b, j) => (
                        <li key={j} className="flex items-start gap-3 md:gap-4 text-[13px] md:text-[14px] text-white/50 text-left md:text-justify leading-snug md:leading-relaxed">
                          <CheckCircle2 size={16} className="mt-0.5 shrink-0 text-white/20 group-hover:text-white/60 transition-colors" />
                          <span className="font-medium">{b}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            ))}
          </div>

          {/* CTA Box */}
          <div className="mt-28 bg-[#000B21] text-white rounded-[2.5rem] p-10 md:p-12 relative overflow-hidden border border-white/10 group hover:border-white/20 transition-all">
            <div className="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-60 rounded-[2.5rem] pointer-events-none" />
            <div className="absolute top-[-40%] left-[-5%] w-[300px] h-[300px] rounded-full opacity-10 blur-[80px] pointer-events-none bg-white" />
            <div className="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
              <div>
                <div className="text-[10px] font-black uppercase tracking-widest text-white/40 mb-3">Open to opportunities</div>
